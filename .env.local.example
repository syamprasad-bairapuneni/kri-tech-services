# ---------------------------------------------------------------------------
# Environment variables for KRI Tech & Services
# Copy this file to `.env.local` and fill in real values when you wire up
# the contact form to a real backend / email service.
# None of these are required to run the site as-is (form is frontend-only).
# ---------------------------------------------------------------------------

# Site URL — used for SEO metadata (Open Graph, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=https://www.kritechservices.com

# --- Contact form backend (choose ONE integration when you add it) ---

# Option A: Resend (https://resend.com) — simple transactional email API
# RESEND_API_KEY=

# Option B: EmailJS (client-side email sending, no backend needed)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Option C: Formspree / Getform / any hosted form endpoint
# NEXT_PUBLIC_FORM_ENDPOINT=

# Option D: Custom API route (e.g. /api/contact) that sends via Nodemailer/SES
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# CONTACT_RECEIVER_EMAIL=abc.xyz@gmail.com
