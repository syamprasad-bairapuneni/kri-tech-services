# ---------------------------------------------------------------------------
# Environment variables for KRI Tech & Services
# Copy this file to `.env.local` (same folder as package.json) and fill in
# real values. Restart `npm run dev` after any change to this file.
# ---------------------------------------------------------------------------

# Site URL — used for SEO metadata (Open Graph, sitemap, canonical links)
NEXT_PUBLIC_SITE_URL=https://www.kritechservices.com

# --- Contact form: Resend (active integration) ---
# 1. Go to https://resend.com and create a free account.
# 2. Go to "API Keys" and create a new key. Paste it below.
RESEND_API_KEY=re_your_api_key_here

# 3. The "from" address. While your domain isn't verified in Resend yet,
#    you MUST use their shared sandbox address below — Resend will reject
#    anything else. Once you verify your own domain in Resend's dashboard,
#    replace this with something like:
#      KRI Tech & Services <hello@kritechservices.com>
RESEND_FROM_EMAIL=KRI Tech & Services <onboarding@resend.dev>

# 4. The inbox that should actually receive consultation requests.
#    NOTE: while using the sandbox "from" address above (domain not yet
#    verified), Resend only allows sending TO the email address you signed
#    up with. Once your domain is verified, you can send to any address.
CONTACT_RECEIVER_EMAIL=abc.xyz@gmail.com

# These three Resend variables are read by src/app/api/contact/route.ts,
# which is called by the contact form on the Contact page.
